{
  "name": "mdbook",
  "version": "0.1.0",
  "description": "Markdown + metadata static site generator. Turns TermX Wiki / GitBook content into a searchable, themeable, multilingual site. Ships as a GitHub Action.",
  "type": "module",
  "bin": {
    "mdbook": "bin/mdbook.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./vitepress": "./src/vitepress.mjs",
    "./theme": "./src/theme/index.mjs"
  },
  "files": [
    "bin",
    "src",
    "action.yml"
  ],
  "scripts": {
    "test:portfolio": "node bin/mdbook.mjs build --project ../portfolio"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.1",
    "js-yaml": "^4.1.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.16.0",
    "node-html-parser": "^9.0.0",
    "picocolors": "^1.1.1",
    "plantuml-encoder": "^1.4.0",
    "vitepress": "^1.6.3",
    "vue": "^3.5.13"
  },
  "license": "MIT"
}
